// Inventory Service - Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Product model
model Product {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  name          String
  sku           String   @unique
  barcode       String?  @unique
  description   String?  @db.Text
  category      String?
  type          String   @default("stockable") // stockable, consumable, service
  unitOfMeasure String  @default("Units") @map("unit_of_measure")
  weight        Decimal? @db.Decimal(10, 2)
  volume        Decimal? @db.Decimal(10, 2)
  cost          Decimal? @db.Decimal(12, 2)
  salePrice     Decimal? @map("sale_price") @db.Decimal(12, 2)
  imageUrl      String?  @map("image_url")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  stockMovements StockMovement[]
  stockLevels    StockLevel[]
  variants       ProductVariant[]
  locations      ProductLocation[]

  @@index([tenantId])
  @@index([sku])
  @@index([barcode])
  @@map("products")
}

// Product Variant
model ProductVariant {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  productId     String   @map("product_id")
  name          String   // e.g., "Size: Large, Color: Red"
  sku           String   @unique
  barcode       String?  @unique
  attributes    Json     // {size: "Large", color: "Red"}
  cost          Decimal? @db.Decimal(12, 2)
  salePrice     Decimal? @map("sale_price") @db.Decimal(12, 2)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  stockLevels   StockLevel[]

  @@index([tenantId])
  @@index([productId])
  @@index([sku])
  @@map("product_variants")
}

// Warehouse model
model Warehouse {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  name          String
  code          String   @unique
  address       Json?    // Address object
  isActive      Boolean  @default(true) @map("is_active")
  settings      Json?    // Warehouse-specific settings
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  locations     Location[]
  stockLevels   StockLevel[]
  stockMovements StockMovement[]
  pickingOrders PickingOrder[]

  @@index([tenantId])
  @@index([code])
  @@map("warehouses")
}

// Location model (storage locations within warehouse)
model Location {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  warehouseId   String   @map("warehouse_id")
  name          String
  barcode       String?  @unique
  locationType  String   @default("internal") @map("location_type") // internal, supplier, customer, inventory, production, transit
  parentId      String?  @map("parent_id")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  stockLevels   StockLevel[]
  productLocations ProductLocation[]

  @@index([tenantId])
  @@index([warehouseId])
  @@index([barcode])
  @@map("locations")
}

// Stock Level (current inventory)
model StockLevel {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  productId     String   @map("product_id")
  variantId     String?  @map("variant_id")
  warehouseId   String   @map("warehouse_id")
  locationId    String?  @map("location_id")
  quantity      Decimal  @default(0) @db.Decimal(12, 2)
  reservedQty   Decimal  @default(0) @map("reserved_qty") @db.Decimal(12, 2)
  availableQty  Decimal  @default(0) @map("available_qty") @db.Decimal(12, 2)
  incomingQty   Decimal  @default(0) @map("incoming_qty") @db.Decimal(12, 2)
  outgoingQty   Decimal  @default(0) @map("outgoing_qty") @db.Decimal(12, 2)
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant       ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  location      Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@unique([productId, variantId, warehouseId, locationId])
  @@index([tenantId])
  @@index([productId])
  @@index([warehouseId])
  @@map("stock_levels")
}

// Stock Movement (inventory transactions)
model StockMovement {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  productId     String   @map("product_id")
  variantId     String?  @map("variant_id")
  warehouseId   String   @map("warehouse_id")
  locationId    String?  @map("location_id")
  type          String   // receipt, delivery, internal, adjustment, production, scrap
  quantity      Decimal  @db.Decimal(12, 2)
  unitCost      Decimal? @map("unit_cost") @db.Decimal(12, 2)
  reference     String?  // Reference to source document
  serialNumber  String?  @map("serial_number")
  lotNumber     String?  @map("lot_number")
  expiryDate    DateTime? @map("expiry_date")
  notes         String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([productId])
  @@index([warehouseId])
  @@index([type])
  @@index([createdAt])
  @@map("stock_movements")
}

// Product Location (put-away rules)
model ProductLocation {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  productId     String   @map("product_id")
  locationId    String   @map("location_id")
  sequence      Int      @default(0) // Priority order
  fixedLocation Boolean  @default(false) @map("fixed_location")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  location      Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([productId, locationId])
  @@index([tenantId])
  @@map("product_locations")
}

// Replenishment Rule
model ReplenishmentRule {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  productId     String   @map("product_id")
  warehouseId   String   @map("warehouse_id")
  ruleType      String   @map("rule_type") // min_max, mto, mps
  minQty        Decimal  @map("min_qty") @db.Decimal(12, 2)
  maxQty        Decimal  @map("max_qty") @db.Decimal(12, 2)
  qtyMultiple   Decimal? @map("qty_multiple") @db.Decimal(12, 2)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([productId])
  @@index([warehouseId])
  @@map("replenishment_rules")
}

// Picking Order
model PickingOrder {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  warehouseId   String   @map("warehouse_id")
  pickingType   String   @map("picking_type") // single, cluster, wave, batch
  status        String   @default("draft") // draft, assigned, in_progress, done, cancelled
  assignedToId  String?  @map("assigned_to_id")
  scheduledDate DateTime? @map("scheduled_date")
  startedAt     DateTime? @map("started_at")
  completedAt   DateTime? @map("completed_at")
  items         Json     // Picking items
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([warehouseId])
  @@index([status])
  @@map("picking_orders")
}

// Inventory Adjustment
model InventoryAdjustment {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  warehouseId   String   @map("warehouse_id")
  reason        String?  // Reason for adjustment
  status        String   @default("draft") // draft, validated, done
  items         Json     // Adjustment items
  validatedBy   String?  @map("validated_by")
  validatedAt   DateTime? @map("validated_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([warehouseId])
  @@index([status])
  @@map("inventory_adjustments")
}

// Cycle Count
model CycleCount {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  warehouseId   String   @map("warehouse_id")
  name          String
  schedule      Json?    // Schedule configuration
  status        String   @default("draft") // draft, in_progress, done
  startedAt     DateTime? @map("started_at")
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([warehouseId])
  @@map("cycle_counts")
}
