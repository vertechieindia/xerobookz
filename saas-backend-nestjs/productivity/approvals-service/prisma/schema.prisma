// Approvals Service - Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Approval Type
model ApprovalType {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  name          String
  description   String?  @db.Text
  category      String?  // travel, payment, procurement, etc.
  approvalMethod String  @default("all") @map("approval_method") // all, any
  hasAmount     Boolean  @default(false) @map("has_amount")
  hasDate       Boolean  @default(false) @map("has_date")
  hasQuantity   Boolean  @default(false) @map("has_quantity")
  customFields  Json?    @map("custom_fields")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  approvers     ApprovalTypeApprover[]
  requests      ApprovalRequest[]

  @@index([tenantId])
  @@index([category])
  @@map("approval_types")
}

// Approval Type Approver
model ApprovalTypeApprover {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  approvalTypeId String  @map("approval_type_id")
  userId        String   @map("user_id")
  sequence      Int      @default(0) // Order of approval
  isRequired    Boolean  @default(true) @map("is_required")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  approvalType  ApprovalType @relation(fields: [approvalTypeId], references: [id], onDelete: Cascade)

  @@unique([approvalTypeId, userId])
  @@index([tenantId])
  @@index([approvalTypeId])
  @@map("approval_type_approvers")
}

// Approval Request
model ApprovalRequest {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  approvalTypeId String  @map("approval_type_id")
  requesterId   String   @map("requester_id")
  title         String
  description   String?  @db.Text
  amount        Decimal?  @db.Decimal(12, 2)
  date          DateTime? @db.Date
  quantity      Decimal?  @db.Decimal(10, 2)
  customData    Json?    @map("custom_data")
  status        String   @default("pending") // pending, approved, refused, cancelled
  requestDate   DateTime @default(now()) @map("request_date")
  approvedAt    DateTime? @map("approved_at")
  refusedAt     DateTime? @map("refused_at")
  refusedReason String?  @map("refused_reason") @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  approvalType  ApprovalType @relation(fields: [approvalTypeId], references: [id])
  approvals     Approval[]

  @@index([tenantId])
  @@index([approvalTypeId])
  @@index([requesterId])
  @@index([status])
  @@index([requestDate])
  @@map("approval_requests")
}

// Approval (Individual approver decision)
model Approval {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  requestId     String   @map("request_id")
  approverId    String   @map("approver_id")
  status        String   @default("pending") // pending, approved, refused
  comment       String?  @db.Text
  approvedAt    DateTime? @map("approved_at")
  refusedAt     DateTime? @map("refused_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  request       ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, approverId])
  @@index([tenantId])
  @@index([requestId])
  @@index([approverId])
  @@index([status])
  @@map("approvals")
}
