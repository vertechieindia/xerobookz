// IoT Service - Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// IoT Box
model IoTBox {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  name          String
  serialNumber  String   @unique @map("serial_number")
  ipAddress     String?  @map("ip_address")
  status        String   @default("offline") // online, offline, error
  lastSeen      DateTime? @map("last_seen")
  firmwareVersion String? @map("firmware_version")
  location      String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  devices       IoTDevice[]

  @@index([tenantId])
  @@index([status])
  @@map("iot_boxes")
}

// IoT Device
model IoTDevice {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  boxId         String   @map("box_id")
  name          String
  deviceType    String   @map("device_type") // printer, scanner, scale, camera, etc.
  deviceModel   String?  @map("device_model")
  connectionType String  @map("connection_type") // usb, wifi, bluetooth, hdmi
  status        String   @default("offline") // online, offline, error
  lastSeen      DateTime? @map("last_seen")
  configuration Json?    // Device-specific configuration
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  box           IoTBox    @relation(fields: [boxId], references: [id], onDelete: Cascade)
  operations    IoTDeviceOperation[]

  @@index([tenantId])
  @@index([boxId])
  @@index([deviceType])
  @@index([status])
  @@map("iot_devices")
}

// IoT Device Operation (links device to business operations)
model IoTDeviceOperation {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  deviceId      String   @map("device_id")
  operationType String   @map("operation_type") // print, scan, measure, capture
  linkedToType  String?  @map("linked_to_type") // quality_check, pos_order, inventory, etc.
  linkedToId    String?  @map("linked_to_id")
  parameters    Json?    // Operation parameters
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  device        IoTDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  measurements  IoTMeasurement[]

  @@index([tenantId])
  @@index([deviceId])
  @@index([operationType])
  @@index([linkedToType, linkedToId])
  @@map("iot_device_operations")
}

// IoT Measurement (from quality measurement tools)
model IoTMeasurement {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  operationId   String   @map("operation_id")
  productId     String?  @map("product_id")
  measurementType String @map("measurement_type") // length, weight, temperature, etc.
  value         Decimal  @db.Decimal(12, 4)
  unit          String
  timestamp     DateTime @default(now())
  metadata      Json?    // Additional measurement data
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  operation     IoTDeviceOperation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([operationId])
  @@index([productId])
  @@index([timestamp])
  @@map("iot_measurements")
}
