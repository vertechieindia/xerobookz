// Studio Service - Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Custom App
model CustomApp {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  name          String
  description   String?  @db.Text
  icon          String?
  menuItems     Json?    @map("menu_items")
  isActive      Boolean  @default(true) @map("is_active")
  createdBy     String   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  models        CustomModel[]
  workflows     Workflow[]
  businessRules BusinessRule[]

  @@index([tenantId])
  @@index([isActive])
  @@map("custom_apps")
}

// Custom Model (Entity)
model CustomModel {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  appId         String?  @map("app_id")
  name          String
  label         String
  description   String?  @db.Text
  tableName     String   @unique @map("table_name")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  app           CustomApp? @relation(fields: [appId], references: [id], onDelete: SetNull)
  fields        CustomField[]
  views         CustomView[]
  records       CustomRecord[]

  @@index([tenantId])
  @@index([appId])
  @@map("custom_models")
}

// Custom Field
model CustomField {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  modelId       String?  @map("model_id")
  baseModel     String?  @map("base_model") // For extending existing models
  name          String
  label         String
  fieldType     String   @map("field_type") // string, integer, decimal, boolean, date, datetime, text, selection, many2one, one2many, many2many
  isRequired     Boolean  @default(false) @map("is_required")
  defaultValue   String?  @map("default_value")
  helpText       String?  @map("help_text") @db.Text
  selectionOptions Json?  @map("selection_options") // For selection fields
  relationModel  String?  @map("relation_model") // For relation fields
  displayOrder   Int      @default(0) @map("display_order")
  isReadonly     Boolean  @default(false) @map("is_readonly")
  conditionalVisibility Json? @map("conditional_visibility") // Conditions for visibility
  conditionalRequired Json? @map("conditional_required") // Conditions for required
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  model         CustomModel? @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([modelId])
  @@index([baseModel])
  @@map("custom_fields")
}

// Custom View
model CustomView {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  modelId       String?  @map("model_id")
  baseModel     String?  @map("base_model")
  viewType      String   @map("view_type") // form, list, kanban, calendar, pivot, graph
  name          String
  isDefault     Boolean  @default(false) @map("is_default")
  viewConfig    Json     @map("view_config") // View structure and layout
  filters       Json?     // Default filters
  groups        Json?     // Default grouping
  sortBy        Json?     @map("sort_by")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  model         CustomModel? @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([modelId])
  @@index([baseModel])
  @@index([viewType])
  @@map("custom_views")
}

// Custom Record (Data for custom models)
model CustomRecord {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  modelId       String   @map("model_id")
  data          Json     // Flexible JSON data
  createdBy     String   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  model         CustomModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([modelId])
  @@index([createdAt])
  @@map("custom_records")
}

// Workflow
model Workflow {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  appId         String?  @map("app_id")
  name          String
  description   String?  @db.Text
  triggerType   String   @map("trigger_type") // on_create, on_update, on_delete, scheduled, manual
  triggerConfig Json     @map("trigger_config")
  actions       Json     // Array of actions to execute
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  app           CustomApp? @relation(fields: [appId], references: [id], onDelete: SetNull)
  executions    WorkflowExecution[]

  @@index([tenantId])
  @@index([appId])
  @@index([isActive])
  @@map("workflows")
}

// Workflow Execution
model WorkflowExecution {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  workflowId    String   @map("workflow_id")
  status        String   @default("pending") // pending, running, completed, failed
  triggerData   Json?    @map("trigger_data")
  result        Json?    // Execution result
  errorMessage  String?  @map("error_message") @db.Text
  startedAt     DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  workflow      Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([workflowId])
  @@index([status])
  @@index([createdAt])
  @@map("workflow_executions")
}

// Business Rule
model BusinessRule {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  appId         String?  @map("app_id")
  name          String
  description   String?  @db.Text
  model         String   // Target model
  condition     Json     // Rule condition
  action        Json     // Rule action
  priority      Int      @default(0)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  app           CustomApp? @relation(fields: [appId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([appId])
  @@index([model])
  @@index([isActive])
  @@map("business_rules")
}

// Document Template
model DocumentTemplate {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  name          String
  model         String   // Target model (invoice, purchase_order, etc.)
  templateType  String   @map("template_type") // pdf, html, xml
  content       String   @db.Text // Template content
  variables     Json?    // Available variables
  isDefault     Boolean  @default(false) @map("is_default")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([model])
  @@index([templateType])
  @@map("document_templates")
}

// Menu Item
model MenuItem {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  appId         String?  @map("app_id")
  parentId      String?  @map("parent_id")
  name          String
  label         String
  icon          String?
  action        String?  // Route/action
  sequence      Int      @default(0)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  app           CustomApp? @relation(fields: [appId], references: [id], onDelete: SetNull)
  parent        MenuItem? @relation("MenuHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children      MenuItem[] @relation("MenuHierarchy")

  @@index([tenantId])
  @@index([appId])
  @@index([parentId])
  @@index([sequence])
  @@map("menu_items")
}
