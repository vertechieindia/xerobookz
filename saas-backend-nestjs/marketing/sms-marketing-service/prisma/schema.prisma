// SMS Marketing Service - Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// SMS Campaign
model SMSCampaign {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  name          String
  message       String   @db.Text
  segment       Json?    // Target segment
  status        String   @default("draft") // draft, scheduled, sending, sent, cancelled
  scheduledAt   DateTime? @map("scheduled_at")
  sentAt        DateTime? @map("sent_at")
  settings      Json?    // Campaign settings
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  messages      SMSMessage[]
  statistics    SMSCampaignStatistic[]

  @@index([tenantId])
  @@index([status])
  @@map("sms_campaigns")
}

// SMS Message (individual SMS sent)
model SMSMessage {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  campaignId    String?  @map("campaign_id")
  recipientPhone String  @map("recipient_phone")
  recipientName String?  @map("recipient_name")
  message       String   @db.Text
  status        String   @default("pending") // pending, sent, delivered, failed, clicked
  sentAt        DateTime? @map("sent_at")
  deliveredAt   DateTime? @map("delivered_at")
  clickedAt     DateTime? @map("clicked_at")
  linkUrl       String?  @map("link_url") // Shortened link
  errorMessage  String?  @map("error_message") @db.Text
  cost          Decimal?  @db.Decimal(10, 4) // Cost in credits
  metadata      Json?    // Additional tracking data
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  campaign      SMSCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([campaignId])
  @@index([recipientPhone])
  @@index([status])
  @@map("sms_messages")
}

// SMS Campaign Statistics
model SMSCampaignStatistic {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  campaignId    String   @map("campaign_id")
  date          DateTime @db.Date
  messagesSent  Int      @default(0) @map("messages_sent")
  messagesDelivered Int  @default(0) @map("messages_delivered")
  messagesClicked Int    @default(0) @map("messages_clicked")
  messagesFailed Int     @default(0) @map("messages_failed")
  totalCost     Decimal  @default(0) @map("total_cost") @db.Decimal(12, 4)
  leadsCreated  Int      @default(0) @map("leads_created")
  revenue       Decimal  @default(0) @db.Decimal(12, 2)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  campaign      SMSCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@index([tenantId])
  @@index([campaignId])
  @@index([date])
  @@map("sms_campaign_statistics")
}

// SMS Credits (account balance)
model SMSCredit {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  amount        Decimal  @db.Decimal(12, 4) // Credits purchased
  cost          Decimal  @db.Decimal(12, 2) // Cost in currency
  currency      String   @default("USD")
  transactionType String @map("transaction_type") // purchase, usage, refund
  description   String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([transactionType])
  @@map("sms_credits")
}
