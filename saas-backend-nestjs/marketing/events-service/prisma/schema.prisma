// Events Service - Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Event
model Event {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  name          String
  description   String?  @db.Text
  eventType     String   @map("event_type") // conference, webinar, festival, class, charity, exhibition
  startDate     DateTime @map("start_date")
  endDate       DateTime @map("end_date")
  location      String?  // Physical location or "Online"
  address       Json?    // Address object
  website       String?  // Event website URL
  imageUrl      String?  @map("image_url")
  status        String   @default("draft") // draft, published, ongoing, completed, cancelled
  isPublished   Boolean  @default(false) @map("is_published")
  seoSettings   Json?    @map("seo_settings")
  settings      Json?    // Event settings
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  tickets       Ticket[]
  registrations EventRegistration[]
  tracks       EventTrack[]
  sponsors     EventSponsor[]
  speakers     EventSpeaker[]

  @@index([tenantId])
  @@index([status])
  @@index([startDate])
  @@map("events")
}

// Ticket
model Ticket {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  eventId       String   @map("event_id")
  name          String
  description   String?  @db.Text
  price         Decimal  @default(0) @db.Decimal(12, 2)
  currency      String   @default("USD")
  quantity      Int?     // null = unlimited
  sold          Int      @default(0)
  isEarlyBird   Boolean  @default(false) @map("is_early_bird")
  earlyBirdEndDate DateTime? @map("early_bird_end_date")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrations EventRegistration[]

  @@index([tenantId])
  @@index([eventId])
  @@map("tickets")
}

// Event Registration
model EventRegistration {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  eventId       String   @map("event_id")
  ticketId      String?  @map("ticket_id")
  attendeeName  String   @map("attendee_name")
  attendeeEmail String   @map("attendee_email")
  attendeePhone String?  @map("attendee_phone")
  status        String   @default("pending") // pending, confirmed, cancelled, attended, no_show
  paymentStatus String   @default("pending") @map("payment_status") // pending, paid, refunded
  totalAmount   Decimal  @map("total_amount") @db.Decimal(12, 2)
  currency      String   @default("USD")
  checkedInAt   DateTime? @map("checked_in_at")
  metadata      Json?    // Additional attendee data
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticket        Ticket?  @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([eventId])
  @@index([attendeeEmail])
  @@index([status])
  @@map("event_registrations")
}

// Event Track (for conferences)
model EventTrack {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  eventId       String   @map("event_id")
  name          String
  description   String?  @db.Text
  startDate     DateTime @map("start_date")
  endDate       DateTime @map("end_date")
  location      String?  // Room/venue
  speakerId     String?  @map("speaker_id")
  status        String   @default("draft") // draft, published, completed
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  speaker       EventSpeaker? @relation(fields: [speakerId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([eventId])
  @@index([startDate])
  @@map("event_tracks")
}

// Event Speaker
model EventSpeaker {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  eventId       String   @map("event_id")
  name          String
  bio           String?  @db.Text
  email         String?
  phone         String?
  imageUrl      String?  @map("image_url")
  company       String?
  jobTitle      String?  @map("job_title")
  socialLinks   Json?    @map("social_links")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tracks        EventTrack[]

  @@index([tenantId])
  @@index([eventId])
  @@map("event_speakers")
}

// Event Sponsor
model EventSponsor {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  eventId       String   @map("event_id")
  name          String
  logoUrl       String?  @map("logo_url")
  website       String?
  sponsorLevel  String   @map("sponsor_level") // gold, silver, bronze, etc.
  amount        Decimal? @db.Decimal(12, 2)
  description   String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([eventId])
  @@index([sponsorLevel])
  @@map("event_sponsors")
}
