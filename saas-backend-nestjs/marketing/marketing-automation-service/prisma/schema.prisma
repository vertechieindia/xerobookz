// Marketing Automation Service - Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Marketing Campaign
model MarketingCampaign {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  name          String
  description   String?  @db.Text
  status        String   @default("draft") // draft, active, paused, completed, archived
  startDate     DateTime? @map("start_date")
  endDate       DateTime? @map("end_date")
  workflow      Json     // Workflow definition (nodes, edges, triggers, actions)
  segment       Json?    // Target segment criteria
  settings      Json?    // Campaign settings
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  activities    CampaignActivity[]
  statistics    CampaignStatistic[]

  @@index([tenantId])
  @@index([status])
  @@map("marketing_campaigns")
}

// Campaign Activity (tracking contacts in workflow)
model CampaignActivity {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  campaignId    String   @map("campaign_id")
  contactId     String   @map("contact_id") // Can be lead, customer, etc.
  contactType   String   @map("contact_type") // lead, customer, contact
  currentNode   String?  @map("current_node") // Current position in workflow
  status        String   @default("active") // active, completed, exited, error
  enteredAt     DateTime @map("entered_at")
  exitedAt      DateTime? @map("exited_at")
  metadata      Json?    // Additional tracking data
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  campaign      MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  events        CampaignEvent[]

  @@index([tenantId])
  @@index([campaignId])
  @@index([contactId])
  @@index([status])
  @@map("campaign_activities")
}

// Campaign Event (actions performed)
model CampaignEvent {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  activityId    String   @map("activity_id")
  eventType     String   @map("event_type") // email_sent, email_opened, email_clicked, action_triggered, etc.
  nodeId        String?  @map("node_id") // Workflow node where event occurred
  actionData    Json?    @map("action_data") // Event-specific data
  timestamp     DateTime @default(now())
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  activity      CampaignActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([activityId])
  @@index([eventType])
  @@index([timestamp])
  @@map("campaign_events")
}

// Campaign Statistics (aggregated)
model CampaignStatistic {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  campaignId    String   @map("campaign_id")
  date          DateTime @db.Date
  contactsEntered Int     @default(0) @map("contacts_entered")
  contactsExited  Int     @default(0) @map("contacts_exited")
  emailsSent    Int      @default(0) @map("emails_sent")
  emailsOpened  Int      @default(0) @map("emails_opened")
  emailsClicked Int      @default(0) @map("emails_clicked")
  actionsTriggered Int   @default(0) @map("actions_triggered")
  leadsCreated  Int      @default(0) @map("leads_created")
  opportunitiesCreated Int @default(0) @map("opportunities_created")
  revenue       Decimal  @default(0) @db.Decimal(12, 2)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  campaign      MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@index([tenantId])
  @@index([campaignId])
  @@index([date])
  @@map("campaign_statistics")
}

// Automation Rule (if/then actions)
model AutomationRule {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  name          String
  description   String?  @db.Text
  triggerType   String   @map("trigger_type") // email_opened, email_clicked, form_submitted, etc.
  triggerConditions Json @map("trigger_conditions") // Conditions for trigger
  actions       Json     // Actions to perform
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([isActive])
  @@map("automation_rules")
}
